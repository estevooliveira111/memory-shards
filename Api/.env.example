# Copie este arquivo para .env e preencha com os seus valores
# cp .env.example .env

# Conexão com o banco de dados SQLite
ConnectionStrings__Default=Data Source=memory-shards.db

# URL base para geração dos links de compartilhamento
App__BaseUrl=https://localhost:7001

# Intervalo do cleanup em minutos (padrão: 30)
App__CleanupIntervalMinutes=30
